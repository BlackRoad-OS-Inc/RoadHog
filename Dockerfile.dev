#
# Development Dockerfile — combined Python + Node image for local dev.
# Used by docker-compose.dev-app.yml for hot-reloading app services.
#

FROM python:3.12.12-slim-bookworm

# uv — fast Python package manager
COPY --from=ghcr.io/astral-sh/uv:0.10.2 /uv /uvx /bin/

# Node.js 24 (just the binary + npm)
COPY --from=node:24.13.0-bookworm-slim /usr/local/bin/node /usr/local/bin/
COPY --from=node:24.13.0-bookworm-slim /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN ln -s ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    corepack enable && corepack prepare pnpm@latest --activate

# System build deps — mirrors production Dockerfile (lines 127-138)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    "libxmlsec1=1.2.37-2" \
    "libxmlsec1-dev=1.2.37-2" \
    libffi-dev \
    zlib1g-dev \
    pkg-config \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /code
