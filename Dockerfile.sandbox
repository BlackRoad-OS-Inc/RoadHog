# Dev sandbox image — uses the same Python base and uv version as the production
# Dockerfile (posthog-build stage) so version pins stay in sync.
# PostHog source is NOT baked in — it's mounted from a host worktree at runtime.

# Same base as the posthog-build stage in Dockerfile
FROM python:3.12.12-slim-bookworm

# Same uv version as Dockerfile
COPY --from=ghcr.io/astral-sh/uv:0.10.2 /uv /uvx /usr/local/bin/

SHELL ["/bin/bash", "-e", "-o", "pipefail", "-c"]

# System deps needed for building Python packages + dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    brotli \
    build-essential \
    curl \
    git \
    jq \
    libffi-dev \
    libpq-dev \
    libxml2-dev \
    libxmlsec1-dev \
    libxslt1-dev \
    pkg-config \
    postgresql-client \
    tmux \
    vim \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Same Node.js version as Dockerfile (NODE_VERSION)
ENV NODE_VERSION=24.13.0
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
        amd64) NODE_ARCH='x64';; \
        arm64) NODE_ARCH='arm64';; \
        *) echo "unsupported: ${ARCH}"; exit 1;; \
    esac && \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" \
    | tar xJ -C /usr/local --strip-components=1 --no-same-owner

# pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# mprocs (process manager used by bin/start)
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
        amd64) MPROCS_ARCH='x86_64';; \
        arm64) MPROCS_ARCH='aarch64';; \
        *) echo "unsupported: ${ARCH}"; exit 1;; \
    esac && \
    curl -fsSL "https://github.com/pvolok/mprocs/releases/latest/download/mprocs-0.9.0-linux-${MPROCS_ARCH}-musl.tar.gz" \
    | tar xz -C /usr/local/bin/

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Pre-built Rust service binaries from CI (same images as docker-compose.base.yml).
# These run inside the container instead of cargo build.
COPY --from=ghcr.io/posthog/posthog/capture:master /usr/local/bin/capture /usr/local/bin/posthog-rs-capture
COPY --from=ghcr.io/posthog/posthog/feature-flags:master /usr/local/bin/feature-flags /usr/local/bin/posthog-rs-feature-flags
COPY --from=ghcr.io/posthog/posthog/property-defs-rs:master /usr/local/bin/property-defs-rs /usr/local/bin/posthog-rs-property-defs-rs
COPY --from=ghcr.io/posthog/posthog/cyclotron-janitor:master /usr/local/bin/cyclotron-janitor /usr/local/bin/posthog-rs-cyclotron-janitor

ENV NODE_ENV=development
WORKDIR /workspace

COPY bin/sandbox-entrypoint.sh /usr/local/bin/sandbox-entrypoint.sh
RUN chmod +x /usr/local/bin/sandbox-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sandbox-entrypoint.sh"]
