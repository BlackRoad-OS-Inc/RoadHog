#!/bin/bash

set -e

# Source utility functions
source "$(dirname "$0")/helpers/_utils.sh"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REGISTRY_DIR="${HOME}/.posthog-sandboxes"
REGISTRY_FILE="${REGISTRY_DIR}/registry.json"
COMPOSE_FILE="${REPO_ROOT}/docker-compose.sandbox.yml"
WORKTREE_BASE="${POSTHOG_WORKTREE_BASE:-${HOME}/.worktrees/posthog}"
PORT_BASE=48001

# Ensure registry exists
ensure_registry() {
    mkdir -p "$REGISTRY_DIR"
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        echo '{}' > "$REGISTRY_FILE"
    fi
}

# Slugify branch name for use as compose project name
slugify() {
    echo "$1" | tr '/' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g'
}

# Get next available port
next_port() {
    ensure_registry
    local max_port=$PORT_BASE
    while IFS= read -r port; do
        if [[ "$port" -ge "$max_port" ]]; then
            max_port=$((port + 1))
        fi
    done < <(jq -r '.[].port // empty' "$REGISTRY_FILE" 2>/dev/null)
    echo "$max_port"
}

# Save sandbox to registry
registry_save() {
    local branch="$1"
    local slug="$2"
    local port="$3"
    local worktree_path="$4"

    ensure_registry
    local tmp=$(mktemp)
    jq --arg b "$branch" --arg s "$slug" --arg p "$port" --arg w "$worktree_path" \
        '.[$b] = {slug: $s, port: ($p | tonumber), worktree: $w}' \
        "$REGISTRY_FILE" > "$tmp" && mv "$tmp" "$REGISTRY_FILE"
}

# Remove sandbox from registry
registry_remove() {
    local branch="$1"
    ensure_registry
    local tmp=$(mktemp)
    jq --arg b "$branch" 'del(.[$b])' "$REGISTRY_FILE" > "$tmp" && mv "$tmp" "$REGISTRY_FILE"
}

# Look up sandbox info
registry_get() {
    local branch="$1"
    local field="$2"
    ensure_registry
    jq -r --arg b "$branch" --arg f "$field" '.[$b][$f] // empty' "$REGISTRY_FILE"
}

# Get compose project name for a branch
project_name() {
    local branch="$1"
    local slug
    slug=$(registry_get "$branch" "slug")
    if [[ -z "$slug" ]]; then
        slug=$(slugify "$branch")
    fi
    echo "sandbox-${slug}"
}

# --- Subcommands ---

cmd_create() {
    local branch="${1:?Branch name required. Usage: sandbox create <branch> [base-branch]}"
    local base_branch="${2:-master}"

    local slug
    slug=$(slugify "$branch")
    local project="sandbox-${slug}"

    # Check if sandbox already exists
    local existing_port
    existing_port=$(registry_get "$branch" "port")
    if [[ -n "$existing_port" ]]; then
        error "Sandbox already exists for branch '${branch}' on port ${existing_port}"
        echo "Use 'sandbox start ${branch}' to start it, or 'sandbox destroy ${branch}' first."
        exit 1
    fi

    local port
    port=$(next_port)

    # Create worktree (or reuse existing one)
    local worktree_path
    worktree_path=$(git worktree list | grep -E "\[${branch}\]$" | awk '{print $1}')

    if [[ -n "$worktree_path" ]]; then
        print_color blue "Reusing existing worktree at ${worktree_path}"
    else
        # Fetch latest from origin so we can find remote branches
        git fetch origin --quiet 2>/dev/null || true

        # Check if the branch already exists (local or remote)
        if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null || \
           git show-ref --verify --quiet "refs/remotes/origin/${branch}" 2>/dev/null; then
            print_color blue "Checking out existing branch ${branch}..."
            "${SCRIPT_DIR}/posthog-worktree" checkout "$branch"
        else
            print_color blue "Creating new branch ${branch} from ${base_branch}..."
            "${SCRIPT_DIR}/posthog-worktree" create "$branch" "$base_branch"
        fi
        worktree_path=$(git worktree list | grep -E "\[${branch}\]$" | awk '{print $1}')
    fi

    if [[ -z "$worktree_path" ]] || [[ ! -d "$worktree_path" ]]; then
        fatal "Worktree not found for branch '${branch}'"
    fi

    # Verify the worktree is a valid git checkout
    if [[ ! -f "${worktree_path}/manage.py" ]]; then
        fatal "Worktree at ${worktree_path} does not contain PostHog code"
    fi

    # Save to registry
    registry_save "$branch" "$slug" "$port" "$worktree_path"

    # Start compose project
    local vite_port=$((port + 1000))
    print_color blue "Starting sandbox '${project}' on port ${port} (Vite: ${vite_port})..."
    SANDBOX_PORT="$port" SANDBOX_VITE_PORT="$vite_port" SANDBOX_CODE="$worktree_path" \
    SANDBOX_UID="$(id -u)" SANDBOX_GID="$(id -g)" \
        docker compose -p "$project" -f "$COMPOSE_FILE" up -d --build

    # Wait for app to be ready
    print_color blue "Waiting for PostHog to start..."
    local max_wait=300
    local elapsed=0
    while [[ $elapsed -lt $max_wait ]]; do
        if curl -sf "http://localhost:${port}/_healthz" > /dev/null 2>&1; then
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))
        echo "  ... waiting (${elapsed}s)"
    done

    if [[ $elapsed -ge $max_wait ]]; then
        print_color yellow "PostHog may still be starting up. Check logs with: sandbox logs ${branch}"
    fi

    echo ""
    success "PostHog running at http://localhost:${port}"
    print_color blue "Worktree: ${worktree_path}"
    print_color blue "Shell:    sandbox shell ${branch}"
    print_color blue "Logs:     sandbox logs ${branch}"
}

cmd_stop() {
    local branch="${1:?Branch name required. Usage: sandbox stop <branch>}"
    local project
    project=$(project_name "$branch")

    print_color blue "Stopping sandbox '${project}'..."
    docker compose -p "$project" -f "$COMPOSE_FILE" stop

    success "Sandbox stopped. Volumes preserved."
}

cmd_start() {
    local branch="${1:?Branch name required. Usage: sandbox start <branch>}"
    local project
    project=$(project_name "$branch")
    local port
    port=$(registry_get "$branch" "port")

    if [[ -z "$port" ]]; then
        fatal "No sandbox found for branch '${branch}'. Create one with: sandbox create ${branch}"
    fi

    local worktree_path
    worktree_path=$(registry_get "$branch" "worktree")

    local vite_port=$((port + 1000))
    print_color blue "Starting sandbox '${project}' on port ${port} (Vite: ${vite_port})..."
    SANDBOX_PORT="$port" SANDBOX_VITE_PORT="$vite_port" SANDBOX_CODE="$worktree_path" \
    SANDBOX_UID="$(id -u)" SANDBOX_GID="$(id -g)" \
        docker compose -p "$project" -f "$COMPOSE_FILE" up -d

    success "PostHog running at http://localhost:${port}"
}

cmd_destroy() {
    local branch="${1:?Branch name required. Usage: sandbox destroy <branch>}"
    local project
    project=$(project_name "$branch")

    print_color yellow "Destroying sandbox '${project}'..."

    # Clean up files that may have been created as root inside the container
    local worktree_path
    worktree_path=$(registry_get "$branch" "worktree")
    if [[ -n "$worktree_path" && -d "$worktree_path" ]]; then
        docker run --rm -v "${worktree_path}:/cleanup" alpine sh -c \
            "rm -rf /cleanup/node_modules /cleanup/.venv /cleanup/.pnpm-store" 2>/dev/null || true
    fi

    # Stop and remove containers + volumes
    docker compose -p "$project" -f "$COMPOSE_FILE" down -v 2>/dev/null || true

    # Remove worktree
    "${SCRIPT_DIR}/posthog-worktree" remove "$branch" 2>/dev/null || true

    # Remove from registry
    registry_remove "$branch"

    success "Sandbox destroyed."
}

cmd_list() {
    ensure_registry

    local branches
    branches=$(jq -r 'keys[]' "$REGISTRY_FILE" 2>/dev/null)

    if [[ -z "$branches" ]]; then
        echo "No sandboxes found. Create one with: sandbox create <branch>"
        return
    fi

    printf "%-40s %-8s %-10s %-s\n" "BRANCH" "PORT" "STATUS" "URL"
    printf "%-40s %-8s %-10s %-s\n" "------" "----" "------" "---"

    while IFS= read -r branch; do
        local port slug project status url
        port=$(registry_get "$branch" "port")
        slug=$(registry_get "$branch" "slug")
        project="sandbox-${slug}"

        # Check if containers are running
        local running
        running=$(docker compose -p "$project" -f "$COMPOSE_FILE" ps --status running -q 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$running" -gt 0 ]]; then
            status="running"
            url="http://localhost:${port}"
        else
            status="stopped"
            url="-"
        fi

        printf "%-40s %-8s %-10s %-s\n" "$branch" "$port" "$status" "$url"
    done <<< "$branches"
}

cmd_shell() {
    local branch="${1:?Branch name required. Usage: sandbox shell <branch>}"
    local slug
    slug=$(registry_get "$branch" "slug")
    if [[ -z "$slug" ]]; then
        slug=$(slugify "$branch")
    fi

    local container="sandbox-${slug}-app-1"
    print_color blue "Attaching to mprocs in ${container}... (detach with Ctrl-b d)"
    docker exec -it "$container" tmux -L sandbox attach-session -t posthog
}

cmd_logs() {
    local branch="${1:?Branch name required. Usage: sandbox logs <branch>}"
    local project
    project=$(project_name "$branch")

    docker compose -p "$project" -f "$COMPOSE_FILE" logs -f app
}

# --- Main ---

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    create)
        cmd_create "$@"
        ;;
    stop)
        cmd_stop "$@"
        ;;
    start)
        cmd_start "$@"
        ;;
    destroy)
        cmd_destroy "$@"
        ;;
    list|ls)
        cmd_list
        ;;
    shell)
        cmd_shell "$@"
        ;;
    logs)
        cmd_logs "$@"
        ;;
    help|*)
        echo "PostHog Dev Sandbox Manager"
        echo ""
        echo "Usage: sandbox <command> [arguments]"
        echo ""
        echo "Commands:"
        echo "  create <branch> [base-branch]   Create a new isolated sandbox"
        echo "  start <branch>                  Start a stopped sandbox"
        echo "  stop <branch>                   Stop a sandbox (preserves state)"
        echo "  destroy <branch>                Destroy a sandbox and clean up"
        echo "  list                            List all sandboxes"
        echo "  shell <branch>                  Open a shell in a sandbox"
        echo "  logs <branch>                   Tail logs from a sandbox"
        echo ""
        echo "Examples:"
        echo "  sandbox create aspicer/cool-feature"
        echo "  sandbox create aspicer/bugfix main"
        echo "  sandbox list"
        echo "  sandbox shell aspicer/cool-feature"
        echo "  sandbox stop aspicer/cool-feature"
        echo "  sandbox start aspicer/cool-feature"
        echo "  sandbox destroy aspicer/cool-feature"
        ;;
esac
